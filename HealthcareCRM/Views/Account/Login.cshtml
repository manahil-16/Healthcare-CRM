@model HealthcareCRM.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - HealthcareCRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="auth-body">
    <div class="auth-wrapper">
        <div class="auth-left">
            <div class="brand-icon">🏥</div>
            <h1>HealthcareCRM</h1>
            <p>A complete platform to manage patients, appointments, and healthcare operations efficiently.</p>
            <div class="feature-list">
                <div class="feature-item"><span>👤</span> Patient Management</div>
                <div class="feature-item"><span>📅</span> Appointment Tracking</div>
                <div class="feature-item"><span>🔒</span> Secure Authentication</div>
                <div class="feature-item"><span>📊</span> Analytics Dashboard</div>
            </div>
        </div>
        <div class="auth-right">
            <div class="auth-form-box">
                <h2>Welcome Back 👋</h2>
                <p class="auth-subtitle">Login to your HealthcareCRM account</p>
                <form asp-action="Login" method="post">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="error-msg">Invalid email or password. Please try again.</div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />
                    </div>
                    <button type="submit" class="btn-login">Login to Account →</button>
                </form>
                <div class="auth-footer">
                    Don't have an account? <a asp-action="Register">Register here</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>