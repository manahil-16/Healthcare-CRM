@model HealthcareCRM.Models.AppointmentViewModel
<form method="post" class="card card-body col-md-8"><input asp-for="Id" type="hidden" /><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="mb-3"><label asp-for="PatientId" class="form-label">Patient</label><select asp-for="PatientId" class="form-select"><option value="0">Select patient</option>@foreach (var patient in Model.Patients) { <option value="@patient.Id">@patient.FullName</option> }</select><span asp-validation-for="PatientId" class="text-danger"></span></div><div class="mb-3"><label asp-for="DoctorId" class="form-label">Doctor</label><select asp-for="DoctorId" class="form-select"><option value="0">Select doctor</option>@foreach (var doctor in Model.Doctors) { <option value="@doctor.Id">@doctor.Name — @doctor.Specialization</option> }</select><span asp-validation-for="DoctorId" class="text-danger"></span></div><div class="mb-3"><label asp-for="AppointmentDate" class="form-label">Date and time</label><input asp-for="AppointmentDate" type="datetime-local" class="form-control" /><span asp-validation-for="AppointmentDate" class="text-danger"></span></div><div class="mb-3"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="3"></textarea></div><button class="btn btn-primary">Save Appointment</button><a asp-action="Index" class="btn btn-secondary mt-2">Cancel</a></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
