@model IEnumerable<HealthcareCRM.Models.Appointment>
@{ ViewData["Title"] = "Appointments"; }
<div class="d-flex justify-content-between align-items-center mb-4"><h2>Appointments</h2><a asp-action="Create" class="btn btn-primary">Book Appointment</a></div>
@if (TempData["Success"] is not null) { <div class="alert alert-success">@TempData["Success"]</div> }
<form method="get" class="mb-3"><select name="status" class="form-select w-auto d-inline" onchange="this.form.submit()"><option value="">All statuses</option>@foreach (var value in new[] { "Pending", "Confirmed", "Cancelled" }) { <option value="@value" selected="@(ViewBag.Status == value)">@value</option> }</select></form>
<div class="table-responsive"><table class="table table-hover"><thead><tr><th>Date & time</th><th>Patient</th><th>Doctor</th><th>Notes</th><th>Status</th><th>Actions</th></tr></thead><tbody>@if (!Model.Any()) { <tr><td colspan="6" class="text-center">No appointments found.</td></tr> } @foreach (var appointment in Model) { <tr><td>@appointment.AppointmentDate.ToString("dd MMM yyyy HH:mm")</td><td>@appointment.Patient?.FullName</td><td>@appointment.Doctor?.Name</td><td>@appointment.Notes</td><td><span class="badge bg-@(appointment.Status == "Confirmed" ? "success" : appointment.Status == "Cancelled" ? "secondary" : "warning")">@appointment.Status</span></td><td><a asp-action="Edit" asp-route-id="@appointment.Id" class="btn btn-sm btn-outline-primary">Edit</a> <form asp-action="UpdateStatus" method="post" class="d-inline"><input type="hidden" name="id" value="@appointment.Id" /><input type="hidden" name="status" value="Cancelled" /><button class="btn btn-sm btn-outline-danger" onclick="return confirm('Cancel this appointment?')" @(appointment.Status == "Cancelled" ? "disabled" : "")>Cancel</button></form></td></tr> }</tbody></table></div>
