@model IEnumerable<HealthcareCRM.Models.Doctor>

@{
    ViewData["Title"] = "Doctors";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Doctors - HealthcareCRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body style="background:#F4F6F9; min-height:100vh;">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid px-4">
            <a class="navbar-brand">🏥 HealthcareCRM</a>
            <div class="d-flex gap-3">
                <a href="/Patient" class="nav-link">Patients</a>
                <a href="/Doctor" class="nav-link">Doctors</a>
                <a href="/Account/Logout" class="nav-link">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Doctors</h2>
            <span class="badge bg-secondary fs-6">Read Only — Full CRUD in Week 3</span>
        </div>

        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Specialization</th>
                    <th>Phone</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            No doctors found. Add some from SSMS or wait for Week 3 CRUD.
                        </td>
                    </tr>
                }
                @foreach (var doctor in Model)
                {
                    <tr>
                        <td>@doctor.Id</td>
                        <td>@doctor.Name</td>
                        <td>@doctor.Specialization</td>
                        <td>@doctor.Phone</td>
                        <td>
                            <span class="badge bg-success">Active</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</body>
</html>